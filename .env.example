# Supabase (REQUIS pour le build)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Vercel Blob Storage (REQUIS pour upload d'images)
BLOB_READ_WRITE_TOKEN=your-blob-token-here

# Make.com Webhook (optionnel - pour publication automatique)
MAKE_WEBHOOK_URL=https://hook.make.com/your-webhook

# Site URL (optionnel - pour les URLs absolues)
NEXT_PUBLIC_SITE_URL=https://keiro.vercel.app

# Google Gemini API (GRATUIT - pour tous les agents IA)
# Obtenez votre clé gratuite sur: https://ai.google.dev
GOOGLE_GEMINI_API_KEY=votre-cle-gemini-ici

# Meta/Instagram API (REQUIS pour publication automatique Instagram)
# Créez une app Meta sur: https://developers.facebook.com/apps/
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
NEXT_PUBLIC_META_REDIRECT_URI=https://keiro.vercel.app/auth/instagram-callback

# Email provider (au moins un des deux requis)
# Brevo (prioritaire) - https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here
# Resend (fallback) - https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
